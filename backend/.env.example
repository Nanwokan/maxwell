PORT=4000
NODE_ENV=development
TRUST_PROXY=false
RATE_LIMIT_ENABLED=true
CORS_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb://<USERNAME>:<PASSWORD>@host1:27017,host2:27017,host3:27017/maxwelldb?ssl=true&replicaSet=<REPLICA_SET>&authSource=admin&retryWrites=true&w=majority&appName=maxwell
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace-with-a-strong-password-at-least-12-characters
SEED_RESET_CONTENT=false
ALLOW_DESTRUCTIVE_SEED=false
